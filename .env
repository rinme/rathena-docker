###############################################################################
# rAthena Docker — Environment Configuration
#
# Copy this file to .env and edit the values as needed.
# All variables use ${VAR:-default} in docker-compose.yml so these are optional.
###############################################################################

# ---- Database ----
DB_IMAGE=mariadb:noble
DB_CONTAINER_NAME=rathena-db
DB_HOST_PORT=3306
DB_ROOT_PASSWORD=ragnarok
DB_NAME=ragnarok
DB_USER=ragnarok
DB_PASSWORD=ragnarok

# ---- Builder / Packet Version ----
BUILDER_CONTAINER_NAME=rathena-builder
BUILDER_CONFIGURE=--enable-packetver=20211103

# ---- Login Server ----
LOGIN_CONTAINER_NAME=rathena-login
LOGIN_HOST_PORT=6900

# ---- Character Server ----
CHAR_CONTAINER_NAME=rathena-char
CHAR_HOST_PORT=6121

# ---- Map Server ----
MAP_CONTAINER_NAME=rathena-map
MAP_HOST_PORT=5121

# ---- phpMyAdmin ----
PHPMYADMIN_IMAGE=phpmyadmin/phpmyadmin
PHPMYADMIN_CONTAINER_NAME=rathena-phpmyadmin
PHPMYADMIN_HOST_PORT=8080
PHPMYADMIN_ARBITRARY=0

# ---- FluxCP ----
FLUXCP_CONTAINER_NAME=rathena-fluxcp
FLUXCP_HOST_PORT=80

# ---- Paths (relative to this directory) ----
# Default layout: rathena-docker/ sits next to rathena/
RATHENA_SOURCE_PATH=../..
RATHENA_PATH=../../sql-files/

# ---- FluxCP-specific settings ----
# These are used to generate the FluxCP config files
FLUXCP_SERVER_ADDRESS=localhost:${FLUXCP_HOST_PORT:-80}
FLUXCP_BASE_URI=/
FLUXCP_FORCE_HTTPS=false
FLUXCP_INSTALLER_PASSWORD=secretpassword
FLUXCP_SERVER_NAME=FluxRO
FLUXCP_DB_HOSTNAME=db
FLUXCP_DB_USERNAME=ragnarok
FLUXCP_DB_PASSWORD=ragnarok
FLUXCP_DB_DATABASE=ragnarok
FLUXCP_LOGIN_ADDR=login
FLUXCP_LOGIN_PORT=6900
FLUXCP_CHAR_ADDR=char
FLUXCP_CHAR_PORT=6121
FLUXCP_MAP_ADDR=map
FLUXCP_MAP_PORT=5121
FLUXCP_BASE_EXP_RATE=100
FLUXCP_JOB_EXP_RATE=100
FLUXCP_MVP_EXP_RATE=100
